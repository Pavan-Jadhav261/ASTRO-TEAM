generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OpdVisit {
  visit_id     String   @id
  token_number String   @unique
  name         String
  age          Int
  gender       String
  phone        String
  symptoms     String
  department   String
  room_number  String?
  patient_id   String?
  created_at   DateTime @default(now())

  patient      Patient? @relation(fields: [patient_id], references: [id])
  prescriptions Prescription[]
  summaries     DoctorSummary[]
}

model Patient {
  id          String     @id @default(cuid())
  phone       String     @unique
  name        String?
  age         Int?
  gender      String?
  allergies   String?
  guardians   String[]   @default([])
  created_at  DateTime   @default(now())
  visits      OpdVisit[]
  prescriptions Prescription[]
  summaries   DoctorSummary[]
  reports     PatientReport[]
  emergencies EmergencyAlert[]
  helpers     PatientHelper[]
}

model Doctor {
  id            String   @id @default(cuid())
  username      String   @unique
  name          String
  department    String
  password_hash String
  created_at    DateTime @default(now())
}

model Hospital {
  id            String   @id @default(cuid())
  hospital_id   String   @unique
  name          String
  address       String?
  password_hash String
  created_at    DateTime @default(now())
}

model Prescription {
  id          String   @id @default(cuid())
  patient_id  String
  visit_id    String?
  medicine    String
  dosage      String?
  frequency   String?
  duration    String?
  created_at  DateTime @default(now())

  patient     Patient  @relation(fields: [patient_id], references: [id])
  visit       OpdVisit? @relation(fields: [visit_id], references: [visit_id])
}

model DoctorSummary {
  id          String   @id @default(cuid())
  patient_id  String
  visit_id    String?
  summary     String
  chiefComplaint String?
  findings    String?
  diagnosis   String?
  plan        String?
  radar_scores Json?
  created_at  DateTime @default(now())

  patient     Patient  @relation(fields: [patient_id], references: [id])
  visit       OpdVisit? @relation(fields: [visit_id], references: [visit_id])
}

model PatientReport {
  id          String   @id @default(cuid())
  patient_id  String
  file_name   String
  storage_path String
  file_url    String?
  created_at  DateTime @default(now())

  patient     Patient  @relation(fields: [patient_id], references: [id])
}

model EmergencyAlert {
  id          String   @id @default(cuid())
  patient_id  String
  reason      String
  location    String?
  symptoms    String?
  summary     String?
  created_by  String?
  status      String   @default("open")
  created_at  DateTime @default(now())

  patient     Patient  @relation(fields: [patient_id], references: [id])

  @@map("emergency_alerts")
}

model NotificationSubscription {
  id          String   @id @default(cuid())
  endpoint    String   @unique
  p256dh      String
  auth        String
  latitude    Float?
  longitude   Float?
  patient_id  String?
  updated_at  DateTime @updatedAt
  created_at  DateTime @default(now())
}

model PatientHelper {
  id         String   @id @default(cuid())
  patient_id String
  chat_id    String   @unique
  username   String?
  first_name String?
  created_at DateTime @default(now())

  patient    Patient  @relation(fields: [patient_id], references: [id])
}
